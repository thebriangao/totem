# ─── Required: fill in before running `npm run cognito-bootstrap` ──────────
WHOOP_EMAIL=your@email.com
WHOOP_PASSWORD=your-whoop-password

# ─── Populated automatically by `npm run cognito-bootstrap`. Do NOT edit. ──
WHOOP_IOS_BEARER_TOKEN=
WHOOP_COGNITO_REFRESH_TOKEN=

# ─── Optional: avoids one redundant bootstrap call per session ─────────────
# Get this from the bootstrap script's output (or any captured JWT).
WHOOP_USER_ID=

# ─── Remote hosting (HTTP transport) ───────────────────────────────────────
# Leave MCP_TRANSPORT unset (or "stdio") for local Claude Desktop / Claude Code.
# Set MCP_TRANSPORT=http to expose the MCP over HTTP for remote clients.
#
#   MCP_TRANSPORT=http
#   MCP_AUTH_TOKEN=<generate with: openssl rand -hex 32>
#   PORT=3000                  # or MCP_HTTP_PORT, default 3000
#   WHOOP_TOKEN_STORE=envfile  # or "memory" for read-only filesystems
#
# See README → "Remote hosting" for the full deploy walkthrough.
MCP_TRANSPORT=
MCP_AUTH_TOKEN=
